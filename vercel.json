{
  "version": 2,
  "installCommand": "pip install -r requirements.txt && python manage.py migrate --noinput",
  "rewrites": [
    {
      "source": "/static/(.*)",
      "destination": "/static/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index.py"
    }
  ],
  "env": {
    "DISABLE_COLLECTSTATIC": "1"
  }
}
