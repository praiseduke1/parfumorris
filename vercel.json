{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/staticfiles/$1"
    },
    {
      "src": "/favicon.ico",
      "dest": "/staticfiles/favicon.svg"
    },
    {
      "src": "/favicon.png",
      "dest": "/staticfiles/favicon.svg"
    },
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ]
}
