{
  "version": 2,
  "functions": {
    "api/index.py": {
      "runtime": "vercel-python@4.3.0",
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/static/(.*)",
      "destination": "/staticfiles/$1"
    },
    {
      "source": "/favicon.ico",
      "destination": "/staticfiles/favicon.svg"
    },
    {
      "source": "/favicon.png",
      "destination": "/staticfiles/favicon.svg"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index.py"
    }
  ]
}
