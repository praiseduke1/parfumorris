{
  "version": 2,
  "builds": [
    {
      "src": "parfumoray/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxDuration": 60,
        "runtime": "python3.12"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "parfumoray/wsgi.py"
    }
  ],
  "env": {
    "DISABLE_COLLECTSTATIC": "1"
  }
}
