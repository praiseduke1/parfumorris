# Django
SECRET_KEY=change-this-to-a-random-secret-key
DEBUG=True
# ALLOWED_HOSTS is ['*'] by default in settings.py
# ALLOWED_HOSTS=localhost,127.0.0.1

# Database (SQLite for local development, PostgreSQL on Vercel via DATABASE_URL)
# On Vercel: set DATABASE_URL=postgres://user:pass@host:5432/db?sslmode=require
DATABASE_URL=

# Email (development: console/file, production: SMTP)
EMAIL_BACKEND=django.core.mail.backends.filebased.EmailBackend
EMAIL_FILE_PATH=emails
# For production SMTP:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@parfumoray.com

# CSRF trusted origins (comma-separated exact origins; add https://yourdomain.com in production)
# NOTE: On Vercel, DynamicCsrfTrustedOriginsMiddleware appends the current origin automatically.
# Still, set VERCEL_URL & VERCEL_PROJECT_PRODUCTION_URL env vars for cold-start coverage.
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Site name (used in Django Sites framework and Allauth)
SITE_NAME=ParfuMoray

# Base URL (used for Midtrans payment callbacks)
# Automatically detected from VERCEL_URL on Vercel; set manually otherwise.
# BASE_URL=http://localhost:8000

# Midtrans (Sandbox / Production)
MIDTRANS_MERCHANT_ID=your-merchant-id
MIDTRANS_CLIENT_KEY=your-client-key
MIDTRANS_SERVER_KEY=your-server-key
MIDTRANS_IS_PRODUCTION=False

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Redis (optional — falls back to local memory cache)
REDIS_URL=redis://127.0.0.1:6379/1

# Komerce Shipping API (RajaOngkir V2)
KOMERCE_API_KEY=your-komerce-api-key
KOMERCE_BASE_URL=https://rajaongkir.komerce.id/api/v1

# Supabase Storage (S3-compatible, production only)
# Set these in Vercel dashboard to persist uploaded images.
# AWS_ACCESS_KEY_ID=your-supabase-s3-access-key
# AWS_SECRET_ACCESS_KEY=your-supabase-s3-secret-key
# AWS_STORAGE_BUCKET_NAME=your-bucket-name
# AWS_S3_ENDPOINT_URL=https://<project>.supabase.co/storage/v1/s3
# AWS_S3_REGION_NAME=ap-southeast-1
